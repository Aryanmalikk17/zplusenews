# Environment Variables for ZPluse News
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/zplusenews?retryWrites=true&w=majority

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_characters
JWT_EXPIRE=30d

# CORS Allowed Origins (comma-separated)
# Add your production domains here
CORS_ORIGIN=https://your-app.onrender.com,https://yourdomain.com,http://localhost:3000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880

# Admin Setup Key (for emergency setup route) - CHANGE IN PRODUCTION!
SETUP_KEY=change_this_to_a_secure_random_string

# ============================================
# CURRENTS API CONFIGURATION
# Sign up at https://currentsapi.services/
# ============================================
CURRENTS_API_KEY=your_currents_api_key_here

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST:
# ============================================
# 1. Set NODE_ENV=production
# 2. Use a strong, random JWT_SECRET (32+ characters)
# 3. Update CORS_ORIGIN with your actual domain(s)
# 4. Change SETUP_KEY to a secure random string
# 5. Ensure MONGO_URI points to your production database
# 6. Add your CURRENTS_API_KEY for live news
# ============================================
